# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# Config (user-specific files; midi-map.yaml.default is tracked)
config.yaml
midi-map.yaml

# Logs
*.log

# samples/ — subdirectory-specific rules live in their own .gitignore files.
# The top-level directory is tracked so its structure (subdirs, .gitkeep,
# per-directory .gitignore) is committed.  Audio and variant content is
# excluded by the .gitignore in each subdirectory.
!samples/

# Local-only extraction script (not distributed; see samples/reference/CREDITS.md)
scripts/extract_gm_drums.py

# Documentation build output
docs/html/
docs/*.html

# Project metadata and instructions
CLAUDE.md
README-AGENTS.md
AGENT-INSTRUCTIONS.md
.vscode/
.claude/
