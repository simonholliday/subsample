# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# Config (user-specific files; midi-map.yaml.default is tracked)
config.yaml
midi-map.yaml
midi-map-*.yaml

# Logs
*.log

# Audio and video files — never tracked anywhere in the repo.
*.wav
*.flac
*.aiff
*.aif
*.ogg
*.mp3
*.mpeg
*.m4a
*.wma
*.opus
*.mp4
*.mkv
*.avi
*.mov

# Analysis sidecars — generated locally, not tracked (except in
# samples/reference/ which un-ignores them via its own .gitignore).
*.analysis.json

# samples/ — directory structure is committed via .gitkeep files.
# Per-directory .gitignore files handle any additional whitelisting
# (e.g. samples/reference/ tracks *.analysis.json sidecars).
!samples/

# Local-only extraction script (not distributed; see samples/reference/CREDITS.md)
scripts/extract_gm_drums.py

# Documentation build output
docs/html/
docs/*.html

# Project metadata and instructions
CLAUDE.md
README-AGENTS.md
AGENT-INSTRUCTIONS.md
.vscode/
.claude/
