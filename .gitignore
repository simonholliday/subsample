# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# Config (user-specific files; midi-map.yaml.default is tracked)
config.yaml
midi-map.yaml

# Audio
samples/

# Logs
*.log

# Generated audio recordings
*.wav
*.flac
*.mp3
*.analysis.json

# Reference directory — track analysis JSONs and credits, ignore everything else.
# These negations must come AFTER the global *.analysis.json rule above.
!reference/
reference/*
!reference/*.analysis.json
!reference/CREDITS.md

# Local-only extraction script (not distributed; see reference/CREDITS.md for provenance)
scripts/extract_gm_drums.py

# Documentation build output
docs/html/
docs/*.html

# Project metadata and instructions
CLAUDE.md
README-AGENTS.md
AGENT-INSTRUCTIONS.md
.vscode/
.claude/

